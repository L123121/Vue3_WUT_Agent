# ======================================================================
# 武理小精灵 — 生产环境变量模板
# 部署前复制为 .env.production 并填入真实值
# ======================================================================

# ---------- 服务器 ----------
PORT=3000
NODE_ENV=production

# ---------- AI 模型服务（阶跃星辰 / 通义千问兼容 API） ----------
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.stepfun.com/v1
AI_MODEL=step-3.7-flash

# ---------- 讯飞知识库（RAG Embedding） ----------
XUNFEI_API_KEY=your_xunfei_api_key_here
XUNFEI_APP_ID=your_xunfei_app_id_here

# ---------- JWT 密钥（生产环境务必改为随机 64 位字符串） ----------
JWT_SECRET=your-random-64-char-secret-here-change-in-production

# ---------- 学校教务系统 ----------
SCHOOL_TP_HOST=https://one.whut.edu.cn
SCHOOL_JW_HOST=https://jwxt.whut.edu.cn
SCHOOL_ENC_KEY=your_school_enc_key_here

# ---------- Redis（必须填，生产环境使用） ----------
REDIS_URL=redis://default:your_redis_password@redis:6379

# ---------- CORS（生产环境建议填写前端域名） ----------
# 不填则允许所有来源（不推荐）
CORS_ORIGIN=https://your-domain.com

# ---------- Puppeteer（Chrome 可执行路径） ----------
# 容器内用系统安装的 chromium
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
